[config]


[[test]]
name = "test rect functions"
script = '''
include <../models/geometry.scad>

rc = rc(size=[4,6], shift=[1,1]);

assert(is_rc(rc));
assert(rc_size(rc).x == 4);
assert(rc_size(rc).y == 6);
assert(rc_left(rc) == -1);
assert(rc_right(rc) == 3);
assert(rc_top(rc) == 4);
assert(rc_bottom(rc) == -2);
assert(rc_shift(rc) == [1,1]);
'''

[[test]]
name = "test rc_from_edges"
script = '''
include <../models/geometry.scad>

rc1 = rc(size=[4,6], shift=[1,1]);
rc2 = rc_from_edges(
    left = rc_left(rc1),
    right = rc_right(rc1),
    bottom = rc_bottom(rc1),
    top = rc_top(rc1)
);
assert(rc1 == rc2);
'''

[[test]]
name = "test rc_divided_horizontally"
script = '''
include <../models/geometry.scad>

rc1 = rc([4,6]);
divisions1 = rc_divided_horizontally(rc1, 2);
assert(divisions1[0] == rc(size=[2,6], shift=[-1,0]));
assert(divisions1[1] == rc(size=[2,6], shift=[1,0]));

rc2 = rc([4,6]);
divisions2 = rc_divided_horizontally(rc2, 1);
assert(divisions2[0] == rc2);

rc3 = rc([6,6]);
divisions3 = rc_divided_horizontally(rc3, 3);
assert(divisions3[0] == rc(size=[2,6], shift=[-2,0]));
assert(divisions3[1] == rc(size=[2,6], shift=[0,0]));
assert(divisions3[2] == rc(size=[2,6], shift=[2,0]));
'''

[[test]]
name = "test normalize_padding"
script = '''
include <../models/geometry.scad>

padding1 = normalize_padding(1);
assert(padding1 == [1,1,1,1]);

padding2 = normalize_padding([1,2]);
assert(padding2 == [1,2,1,2]);

padding3 = normalize_padding([1,2,1,3]);
assert(padding3 == [1,2,1,3]);
'''

[[test]]
name = "test apply_padding"
script = '''
include <../models/geometry.scad>

rc1 = rc(size=[4,6], shift=[1,1]);
rc2 = apply_padding(rc1, 1);
assert(rc2 == rc(size=[6,8], shift=[1,1]));
'''

[[test]]
name = "test zero rc with padding"
script = '''
include <../models/geometry.scad>
rc1 = rc(size=[0,0], shift=[0,0]); 
rc2 = apply_padding(rc1, 4);
assert(rc2 == rc(size=[8,8], shift=[0,0]));
'''

[[test]]
name = "test 1 rc with 0 padding"
script = '''
include <../models/geometry.scad>
rc1 = rc(size=[1,1], shift=[1,1]); 
rc2 = apply_padding(rc1, 0);
assert(rc2 == rc1);
'''

[[test]]
name = "test rc_union"
script = '''
include <../models/geometry.scad>
rc1 = rc(size=[4,6], shift=[1,1]);
rc2 = rc(size=[4,6], shift=[-1,-1]);
rc3 = rc_union(rc1, rc2);
assert(rc3 == rc(size=[6,8], shift=[0,0]));
'''

[[test]]
name = "test centered_bounding_rc"
script = '''
include <../models/geometry.scad>

rc1 = rc(size=[4,6], shift=[1,1]);
rc2 = centered_bounding_rc(rc1);
assert(rc2 == rc(size=[6,8], shift=[0,0]));

rc3 = rc(size=[4,6], shift=[-1,-1]);
rc4 = centered_bounding_rc(rc3);
assert(rc4 == rc(size=[6,8], shift=[0,0]));
'''

[[test]]
name = "test cubiod functions"
script = '''
include <../models/geometry.scad>

cu1 = cu(size=[2,2,2], shift=[-1,-1,-1]);
assert(is_cu(cu1));
assert(cu_size(cu1).x == cu_size(cu1).z);

center1 = cu_shift(cu1);
assert(center1 == [-1,-1, -1]);
'''

[[test]]
name = "test alignment_shift"
script = '''
include <../models/geometry.scad>
bounding_rc = rc(size=[10,10], shift=[0,0]);
shiftLeft = alignment_shift(bounding_rc, LEFT, [2,2]);
assert(shiftLeft == [-4,0]);   
shiftBack = alignment_shift(bounding_rc, BACK, [2,2]);
assert(shiftBack == [0,4]);    
shiftFrontRight = alignment_shift(bounding_rc, FRONT+RIGHT, [2,2]);  
assert(shiftFrontRight == [4,-4]);

bounding_rc2 = rc(size=[10,10], shift=[20,20]);
shiftLeft2 = alignment_shift(bounding_rc2, LEFT, [2,2]);
assert(shiftLeft2 == [16,20]);   
shiftBack2 = alignment_shift(bounding_rc2, BACK, [2,2]);
assert(shiftBack2 == [20,24]);    
shiftFrontRight2 = alignment_shift(bounding_rc2, FRONT+RIGHT, [2,2]);  
assert(shiftFrontRight2 == [24,16]);
'''

[[test]]
name = "test split"
script = '''
include <../models/geometry.scad>

r = rc([8,8], [4,4]);
split1 = rc_split(r, dx=1);
assert(len(split1) == 2);
assert(split1[0] == rc([1,8], [0.5, 4]));
assert(split1[1] == rc([7,8], [4.5, 4]));

split2 = rc_split(r, dx=-2);
assert(len(split1) == 2);
assert(split2[0] == rc([6,8], [3, 4]));
assert(split2[1] == rc([2,8], [7, 4]));

split3 = rc_split(r, dy=1);
assert(split3[0] == rc([8,1], [4, 0.5]));
assert(split3[1] == rc([8,7], [4, 4.5]));

split4 = rc_split(r, dy=-2);
assert(split4[0] == rc([8,6], [4, 3]));
assert(split4[1] == rc([8,2], [4, 7]));
'''