[config]


[[test]]
name = "test rect functions"
script = '''
include <../models/geometry.scad>

rc = rc(-1,-2,4,6);

assert(is_rc(rc))
assert(rc_x(rc) == -1);
assert(rc_y(rc) == -2);
assert(rc_dx(rc) == 4);
assert(rc_dy(rc) == 6);
assert(rc_left(rc) == -1);
assert(rc_right(rc) == 3);
assert(rc_top(rc) == 4);
assert(rc_bottom(rc) == -2);
assert(rc_shift(rc) == [1,1]);
'''

[[test]]
name = "test rc_from_edges"
script = '''
include <../models/geometry.scad>

rc1 = rc(-1,-2,4,6);
rc2 = rc_from_edges(
    left = rc_left(rc1),
    right = rc_right(rc1),
    top = rc_top(rc1),
    bottom = rc_bottom(rc1)
);
assert(rc1 == rc2);
'''

[[test]]
name = "test shifted_rc"
script = '''
include <../models/geometry.scad>

rc1 = rc(-1,-2,4,6);
rc2 = shifted_rc(
    dx = rc_dx(rc1),
    dy = rc_dy(rc1),
    shift_x = rc_shift(rc1)[0],
    shift_y = rc_shift(rc1)[1]
);
assert(rc1 == rc2);
'''

[[test]]
name = "test rc_divided_horizontally"
script = '''
include <../models/geometry.scad>

rc1 = rc(-2,-3,4,6);
divisions = rc_divided_horizontally(rc1, 2);
assert(divisions[0] == [-2,-3,2,6]);
assert(divisions[1] == [0,-3,2,6]);
'''

[[test]]
name = "test normalize_padding"
script = '''
include <../models/geometry.scad>

padding1 = normalize_padding(1);
assert(padding1 == [1,1,1,1]);

padding2 = normalize_padding([1,2]);
assert(padding2 == [1,2,1,2]);

padding3 = normalize_padding([1,2,1,3]);
assert(padding3 == [1,2,1,3]);

'''
[[test]]
name = "test apply_padding"
script = '''
include <../models/geometry.scad>

rc1 = rc(-1,-2,4,6);
rc2 = apply_padding(rc1, 1);
assert(rc2 == [-2,-3,6,8]);
'''

[[test]]
name = "test grow_to_center"
script = '''
include <../models/geometry.scad>

rc1 = shifted_rc(4, 6, shift_x=1, shift_y=1);
rc2 = grow_to_center(rc1);
assert(rc2 == [-3,-4,6,8]);

rc3 = shifted_rc(4,6, shift_x=-1, shift_y=-1);
rc4 = grow_to_center(rc3);
assert(rc4 == [-3,-4,6,8]);
'''

[[test]]
name = "test cubiod functions"
script = '''
include <../models/geometry.scad>

cu1 = cu(-1,-1,-1,2,2,2);
assert(is_cu(cu1));
assert(cu_dx(cu1) == cu_dz(cu1));

center1 = cu_center(cu1);
assert(center1 == [0,0,0]);
'''

[[test]]
name = "test cubiod and size"
script = '''
include <../models/geometry.scad>

size = [2,4,6];
cu = cu_from_size(size);

assert(cu_center(cu) == [0,0,0]);
assert(cu_size(cu) == size);
'''
