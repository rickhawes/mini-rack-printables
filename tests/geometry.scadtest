[config]


[[test]]
name = "test rect functions"
script = '''
include <../models/geometry.scad>

rc = build_rect(-1,-2,4,6);

assert(is_rect(rc))
assert(rect_x(rc) == -1);
assert(rect_y(rc) == -2);
assert(rect_dx(rc) == 4);
assert(rect_dy(rc) == 6);
assert(rect_left(rc) == -1);
assert(rect_right(rc) == 3);
assert(rect_top(rc) == 4);
assert(rect_bottom(rc) == -2);
assert(rect_offset_x(rc) == 1);
assert(rect_offset_y(rc) == 1);
assert(rect_offset(rc) == [1,1]);
'''

[[test]]
name = "test rect_from_edges"
script = '''
include <../models/geometry.scad>

rc1 = build_rect(-1,-2,4,6);
rc2 = rect_from_edges(
    left = rect_left(rc1),
    right = rect_right(rc1),
    top = rect_top(rc1),
    bottom = rect_bottom(rc1)
);
assert(rc1 == rc2);
'''

[[test]]
name = "test build_rect_with_offset"
script = '''
include <../models/geometry.scad>

rc1 = build_rect(-1,-2,4,6);
rc2 = build_rect_with_offset(
    dx = rect_dx(rc1),
    dy = rect_dy(rc1),
    offset_x = rect_offset(rc1)[0],
    offset_y = rect_offset(rc1)[1]
);
assert(rc1 == rc2);
'''

[[test]]
name = "test normalize_padding"
script = '''
include <../models/geometry.scad>

padding1 = normalize_padding(1);
assert(padding1 == [1,1,1,1]);

padding2 = normalize_padding([1,2]);
assert(padding2 == [1,2,1,2]);

padding3 = normalize_padding([1,2,1,3]);
assert(padding3 == [1,2,1,3]);

'''
[[test]]
name = "test apply_padding"
script = '''
include <../models/geometry.scad>

rc = build_rect(-1,-2,4,6);
rc1 = apply_padding(rc, 1);
assert(rc1 == [-2,-3,6,8]);
'''

[[test]]
name = "test grow_to_center"
script = '''
include <../models/geometry.scad>

rc1 = build_rect_with_offset(4,6, offset_x=1, offset_y=1);
rc2 = grow_to_center(rc1);
assert(rc2 == [-3,-4,6,8]);

rc3 = build_rect_with_offset(4,6, offset_x=-1, offset_y=-1);
rc4 = grow_to_center(rc3);
assert(rc4 == [-3,-4,6,8]);
'''