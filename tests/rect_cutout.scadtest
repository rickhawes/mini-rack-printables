[config]


[[test]]
name = "test rect_cutout builder"
script = '''
include <../models/rect_cutout.scad>

size = [4,6];
rc = rect_cutout(size);

assert(is_struct(rc));
assert(get_type(rc) == PART_TYPE);
assert(get_subtype(rc) == RECT_CUTOUT_TYPE);
assert(is_rect_cutout(rc));
'''


[[test]]
name = "test render_rect_cutout"
script = '''
include <../models/rect_cutout.scad>
include <test_assembly.scad>

size = [4,6];;
rc1 = rect_cutout(size);
test_render_part(rc1, section_size = [100,100,5]);
'''