[config]


[[test]]
name = "Test divide_section"
script = '''
include <../models/parts/div.scad>

part1 = part_base(kind="test1");
sections = divide_section(sub_parts=[part1], section_size=[10,10,1]);

assert(len(sections) == 1);
assert(division_part(sections[0]) == part1);
assert(division_size(sections[0]) == [10,10,1]);
assert(division_shift(sections[0]) == [0,0]);
'''

[[test]]
name = "Test divide_section with shift"
script = '''
include <../models/parts/div.scad>

part1 = part_base(kind="test1", shift=[1,1]);
sections = divide_section(sub_parts=[part1], section_size=[10,10,1]);

assert(division_part(sections[0]) == part1);
assert(division_size(sections[0]) == [10,10,1]);
assert(division_shift(sections[0]) == [1,1]);
'''

[[test]]
name = "Test divide_section into 3"
script = '''
include <../models/parts/div.scad>

part1 = part_base(kind="test1", shift=[1,1]);
sections = divide_section(sub_parts=[part1, part1, part1], section_size=[30,10,1]);

assert(division_part(sections[1]) == part1);
assert(division_size(sections[1]) == [10,10,1]);

assert(division_shift(sections[0]) == [-9,1]);
assert(division_shift(sections[1]) == [1,1]);
assert(division_shift(sections[2]) == [11,1]);
'''

[[test]]
name = "Test divide_section vertically"
script = '''
include <../models/parts/div.scad>

part1 = part_base(kind="test1", shift=[1,1]);
sections = divide_section(sub_parts=[part1, part1, part1], section_size=[10,30,1], dir=VERTICAL);

assert(division_shift(sections[0]) == [1,-9]);
assert(division_shift(sections[1]) == [1,1]);
assert(division_shift(sections[2]) == [1,11]);
'''