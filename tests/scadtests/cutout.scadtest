[config]
enabled_features = ["object-function"]

[[test]]
name = "test cutout builder"
script = '''
include <../models/parts/cutout.scad>

size = [4,6];
co = cutout(rect_size=size);

assert(is_cutout(co));
assert(co.rect_size == size);
'''

[[test]]
name = "test cutout builder with radius"
script = '''
include <../models/parts/cutout.scad>
co = cutout(radius=4);
assert(is_cutout(co));
assert(co.radius == 4);
assert(co.layout_size == [8,8]);
'''

[[test]]
name = "test cutout builder with slot"
script = '''
include <../models/parts/cutout.scad>
partBottom = cutout(
    rect_size = [0,10],
    radius = 3.0,
    align = FRONT,
    //rib_size = rib_size
);
assert(is_cutout(partBottom));
assert(partBottom.layout_size == [6,16]);
'''

[[test]]
name = "test render_cutout"
script = '''
include <../models/parts/cutout.scad>
include <test_assembly.scad>

size = [4,6];;
rc1 = cutout(rect_size=size);
test_render_part(rc1, section_size = [100,100,5]);
'''